<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <org.osmdroid.views.MapView
            android:id="@+id/mapCoarse"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="#AA000000"
            android:orientation="vertical"
            android:padding="6dp">

            <TextView
                android:id="@+id/labelCoarse"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="[BUG]  FINE → lastCoarseLocation"
                android:textColor="#FF7043"
                android:textStyle="bold"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvCoarseInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Waiting..."
                android:textColor="#CCCCCC"
                android:fontFamily="monospace"
                android:textSize="11sp" />
        </LinearLayout>
    </FrameLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#FF5722" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <org.osmdroid.views.MapView
            android:id="@+id/mapFine"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="#AA000000"
            android:orientation="vertical"
            android:padding="6dp">

            <TextView
                android:id="@+id/labelFine"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="[FIX]  FINE → lastFineLocation"
                android:textColor="#66BB6A"
                android:textStyle="bold"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvFineInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Waiting..."
                android:textColor="#CCCCCC"
                android:fontFamily="monospace"
                android:textSize="11sp" />
        </LinearLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:background="#212121"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:text="Waiting for location..." />
</LinearLayout>
