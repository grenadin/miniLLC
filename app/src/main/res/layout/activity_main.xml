<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D1117"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp">

        <TextView
            android:id="@+id/btnTabMap"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:padding="8dp"
            android:text="🗺 Map"
            android:textColor="#58A6FF"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnTabLog"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:padding="8dp"
            android:text="📜 Log"
            android:textColor="#C9D1D9"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnStopRecording"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_btn_stop"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Stop recording" />

        <TextView
            android:id="@+id/btnRecord"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_code_toggle"
            android:backgroundTint="#F85149"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="REC"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnCodeBug"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_code_toggle"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="&lt;/&gt;"
            android:textColor="#58A6FF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnShare"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:src="@drawable/ic_btn_share"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Share recording"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#161B22"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvRecordingStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:padding="6dp"
            android:text="Not recording"
            android:textColor="#8B949E"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/btnDelete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_code_toggle"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="Del"
            android:textColor="#F85149"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/pageMap"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <org.osmdroid.views.MapView
                    android:id="@+id/mapCoarse"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:background="#AA000000"
                    android:orientation="vertical"
                    android:padding="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GRANULARITY_FINE → lastCoarseLocation"
                        android:textColor="#FF7043"
                        android:textStyle="bold"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvCoarseInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Waiting..."
                        android:textColor="#CCCCCC"
                        android:fontFamily="monospace"
                        android:textSize="11sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical|end"
                    android:layout_margin="6dp"
                    android:background="#CC0D1117"
                    android:orientation="vertical"
                    android:padding="2dp">

                    <TextView
                        android:id="@+id/btnZoomInBug"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="+"
                        android:textColor="#C9D1D9"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvZoomLevelBug"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="15"
                        android:textColor="#8B949E"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/btnZoomOutBug"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="−"
                        android:textColor="#C9D1D9"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ScrollView
                    android:id="@+id/codePanelBug"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_gravity="top"
                    android:background="#0D1117"
                    android:padding="10dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvCodeBug"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:textColor="#C9D1D9"
                        android:textSize="11sp" />
                </ScrollView>

            </FrameLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#FF5722" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <org.osmdroid.views.MapView
                    android:id="@+id/mapFine"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:background="#AA000000"
                    android:orientation="vertical"
                    android:padding="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GRANULARITY_FINE → lastFineLocation"
                        android:textColor="#66BB6A"
                        android:textStyle="bold"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvFineInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Waiting..."
                        android:textColor="#CCCCCC"
                        android:fontFamily="monospace"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical|end"
                    android:layout_margin="6dp"
                    android:background="#CC0D1117"
                    android:orientation="vertical"
                    android:padding="2dp">

                    <TextView
                        android:id="@+id/btnZoomInFix"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="+"
                        android:textColor="#C9D1D9"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvZoomLevelFix"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="15"
                        android:textColor="#8B949E"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/btnZoomOutFix"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="−"
                        android:textColor="#C9D1D9"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ScrollView
                    android:id="@+id/codePanelFix"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_gravity="top"
                    android:background="#0D1117"
                    android:padding="10dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvCodeFix"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:textColor="#C9D1D9"
                        android:textSize="11sp" />
                </ScrollView>
            </FrameLayout>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:background="#212121"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:text="Waiting for location..." />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/pageLog"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#000000"
            android:orientation="vertical"
            android:padding="8dp"
            android:visibility="gone">

            <ScrollView
                android:id="@+id/scrollLogViewer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#000000"
                android:fadeScrollbars="false"
                android:scrollbarStyle="insideOverlay"
                android:scrollbars="vertical">

                <TextView
                    android:id="@+id/tvLogViewer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="No log entries yet — press ⏺ Record to start."
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />
            </ScrollView>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
